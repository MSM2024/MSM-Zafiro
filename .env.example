# ZAFIRO + MSM — Environment Variables
# Copy this file to .env.local and fill in your values.

# --- SUPABASE (Auth + Database) ---
# Required for FASE 2+. Auth falls back to localStorage if unset.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Default admin email for OWNER role (used in auth migration scripts)
ZAFIRO_ADMIN_EMAIL=admin@zafiro.app
ZAFIRO_ADMIN_PASSWORD=changeme_in_production

# --- STRIPE (Payments) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key
STRIPE_SECRET_KEY=sk_live_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Price IDs
NEXT_PUBLIC_STRIPE_PRICE_PRO=price_pro_monthly_id
NEXT_PUBLIC_STRIPE_PRICE_CUBA_PLUS=price_cuba_plus_monthly_id

# --- GEMINI AI (ELIANA) ---
GEMINI_API_KEY=your-gemini-api-key

# --- OPENAI AI (ELIANA Multi-Provider) ---
# Optional. ELIANA can use OpenAI GPT-4o Mini as a secondary AI provider.
# Falls back to Gemini / knowledge base if unset.
OPENAI_API_KEY=sk-your-openai-api-key

# --- ANTHROPIC AI (ELIANA Multi-Provider) ---
# Optional. ELIANA can use Anthropic Claude 3 Haiku as a tertiary AI provider.
# Falls back to Gemini / OpenAI / knowledge base if unset.
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# --- WHATSAPP BUSINESS (Single) ---
# WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
# WHATSAPP_ACCESS_TOKEN=your-access-token
# WHATSAPP_APP_SECRET=your-app-secret
# WHATSAPP_VERIFY_TOKEN=zafiro_verify_2026

# --- WHATSAPP BUSINESS (Multi-Node) ---
# Add up to 9 additional WhatsApp Business nodes:
# WHATSAPP_PHONE_NUMBER_ID_1=second-phone-number-id
# WHATSAPP_ACCESS_TOKEN_1=second-access-token
# WHATSAPP_PHONE_NUMBER_ID_2=third-phone-number-id
# WHATSAPP_ACCESS_TOKEN_2=third-access-token

# --- AUDIT LOG ---
AUDIT_LOG_PATH=./audit.log

# --- NEXT.JS ---
NEXT_PUBLIC_APP_URL=http://localhost:3001
