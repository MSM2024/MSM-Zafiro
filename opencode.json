{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    "docs/ZAFIRO_IMAGE_AUDIT.md"
  ],
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "edit": "allow",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git branch*": "allow",
      "npm run lint*": "allow",
      "npm run type-check*": "allow",
      "npm run test*": "allow",
      "npm run build*": "allow",
      "npm install*": "ask",
      "git commit*": "ask",
      "git push*": "deny",
      "git clean*": "deny",
      "git reset --hard*": "deny",
      "rm *": "deny",
      "rmdir *": "deny",
      "del *": "deny",
      "Remove-Item *": "deny",
      "npx supabase db reset*": "deny",
      "npx supabase db push*": "ask",
      "vercel --prod*": "deny"
    }
  }
}
